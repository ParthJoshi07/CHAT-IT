{
  "version": 2,
  "buildCommand": "npm install --prefix client && npm install --prefix server && npm run build --prefix client",
  "outputDirectory": "client/dist",
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "server/server.js": {
      "runtime": "nodejs20.x",
      "memory": 1024
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/client/dist/$1"
    }
  ]
}
